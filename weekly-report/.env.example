# GitHub token (required for higher rate limits and private repos)
GITHUB_TOKEN=ghp_your_token_here

# LLM Provider override (ollama, anthropic, openai)
# LLM_PROVIDER=ollama

# Anthropic API key (only needed if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key (only needed if using openai provider)
# OPENAI_API_KEY=sk-your-key-here
